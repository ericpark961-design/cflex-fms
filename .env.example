# cflex-api side (set in /opt/cflex-v2/cflex-api/.env)
# ── Sentinel / probe ──
SC_INTERNAL_URL=http://localhost:3200
INTERNAL_API_KEY=
RUNLESS_UC_URL=http://localhost:3100

# ── Anthropic (AI auto-RCA) ──
ANTHROPIC_API_KEY=
FMS_RCA_MODEL=claude-haiku-4-5-20251001

# ── Resend (monthly PDF email) ──
RESEND_API_KEY=

# ── PDF output directory ──
FMS_MEDIA_DIR=/opt/cflex-v2/cflex-api/data/fms-reports

# ── Device control (per-tenant, stored in fms_control_config) ──
# Get these from Schneider Electric Partner Manager:
#   exchange.se.com → "EcoStruxure IT for ISV/MSP"
# Then fill via the Admin → Device Control UI.
# (Not env vars — kept in DB so they can be rotated without redeploy.)
